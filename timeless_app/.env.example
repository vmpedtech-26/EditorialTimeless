# Copia este archivo como .env y completa tu API Key de Google AI Studio
# NO subas .env a un repositorio público

GEMINI_API_KEY=pega_tu_api_key_aqui

# Puerto del servidor (por defecto: 3000)
PORT=3000

# Clave pública de Stripe (para el cliente)
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Credenciales de dLocal Go
DLOCAL_LOGIN=tu_x_login_aqui
DLOCAL_TRANS_KEY=tu_x_trans_key_aqui
DLOCAL_SECRET_KEY=tu_secret_key_aqui
DLOCAL_SMARTFIELDS_API_KEY=tu_smartfields_api_key_aqui
DLOCAL_SANDBOX=true
